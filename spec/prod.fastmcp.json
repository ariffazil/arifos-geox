{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "source": {
    "type": "filesystem",
    "path": "arifosmcp/runtime/server.py",
    "entrypoint": "mcp"
  },
  "environment": {
    "type": "uv",
    "python": ">=3.12",
    "dependencies": ["fastmcp==3.0.2", "arifos"],
    "editable": ["."]
  },
  "deployment": {
    "transport": "http",
    "port": 8080,
    "path": "/mcp/",
    "log_level": "INFO"
  }
}
