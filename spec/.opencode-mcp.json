{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "jina-reader": {
      "type": "remote",
      "url": "https://mcp.jina.ai/v1",
      "headers": {
        "Authorization": "Bearer ${JINA_API_KEY}"
      },
      "enabled": true,
      "timeout": 8000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "Authorization": "Bearer ${CONTEXT7_API_KEY}"
      },
      "enabled": true,
      "timeout": 8000
    }
  }
}
