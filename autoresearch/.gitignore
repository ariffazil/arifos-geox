# Autoresearch - Files to ignore

# Experiment results (large, auto-generated)
results.tsv
*.tsv

# Benchmark outputs
benchmark_results.json
*.benchmark.json

# Python cache
__pycache__/
*.pyc
*.pyo

# Experiment artifacts
experiments/**/artifacts/
experiments/**/checkpoints/
experiments/**/logs/

# Local config overrides
config/local*
config/*.local

# Temporary files
*.tmp
*.log
.DS_Store
