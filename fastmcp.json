{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "source": {
    "type": "filesystem",
    "path": "geox_mcp_server.py",
    "entrypoint": "mcp"
  },
  "environment": {
    "type": "uv",
    "python": ">=3.10",
    "dependencies": [
      "pydantic>=2.0",
      "fastapi>=0.100",
      "uvicorn>=0.20",
      "httpx>=0.24",
      "fastmcp>=0.12.0",
      "numpy",
      "pillow"
    ],
    "editable": ["."]
  },
  "deployment": {
    "transport": "stdio",
    "log_level": "INFO",
    "env": {
      "GEOX_VERSION": "0.4.2",
      "DITEMPA": "BUKAN_DIBERI"
    }
  }
}
