{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "provider_soul_profile",
  "description": "Hardened identity soul — defines the 'spirit' of the model family for routing and alignment.",
  "type": "object",
  "required": [
    "provider_key",
    "family_key",
    "soul_label",
    "in_one_sentence",
    "communication_style",
    "reasoning_style",
    "best_fit_roles",
    "worst_fit_roles",
    "when_to_use",
    "when_not_to_use",
    "key_differentiators"
  ],
  "properties": {
    "provider_key": {
      "type": "string",
      "description": "Provider organization (e.g., openai, anthropic, xai)"
    },
    "family_key": {
      "type": "string",
      "description": "Model family identifier (e.g., gpt, claude, grok)"
    },
    "soul_label": {
      "type": "string",
      "description": "Human-centric archetype label (e.g., careful_makcik_reviewer)"
    },
    "in_one_sentence": {
      "type": "string",
      "description": "One-line distillation of the soul's essence"
    },
    "communication_style": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tactical communication style traits"
    },
    "reasoning_style": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Cognitive reasoning patterns"
    },
    "best_fit_roles": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Roles where this soul excels"
    },
    "worst_fit_roles": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Roles where this soul struggles or creates friction"
    },
    "when_to_use": {
      "type": "string"
    },
    "when_not_to_use": {
      "type": "string"
    },
    "key_differentiators": {
      "type": "object",
      "required": [
        "context_handling",
        "truth_vs_speed",
        "cultural_anchor",
        "product_vs_model"
      ],
      "properties": {
        "context_handling": { "type": "string" },
        "truth_vs_speed": { "type": "string" },
        "cultural_anchor": { "type": "string" },
        "product_vs_model": { "type": "string" }
      }
    }
  }
}
