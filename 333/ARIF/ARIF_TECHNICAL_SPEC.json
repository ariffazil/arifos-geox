{
  "project": "A-RIF",
  "full_name": "Accountable Retrieval & Inference Framework",
  "version": "1.0.0",
  "description": "Governed retrieval-inference-governance architecture",
  "formula": "RAG + Validation + Verification + Decision Governance",
  "modules": {
    "M1": {
      "name": "Intake Module",
      "role": "Normalizes incoming user request",
      "inputs": ["raw user query", "optional metadata", "optional session state", "optional authority context"],
      "outputs": ["normalized query object", "session id", "declared intent", "domain hint", "risk hint"],
      "failure_conditions": ["malformed input", "unresolved ambiguity", "unsupported modality"],
      "output_schema": {
        "session_id": "string",
        "query_text": "string",
        "intent_type": "enum(qa|analysis|classification|decision_support|drafting)",
        "domain": "string|null",
        "risk_level": "enum(low|medium|high)",
        "requires_human": "boolean"
      }
    },
    "M2": {
      "name": "Governance Gate",
      "role": "Determines whether the request may proceed",
      "inputs": ["normalized query object", "policy rules", "authority context", "risk model"],
      "outputs": ["decision: allow/narrow/refuse/hold", "allowed sources", "allowed actions", "response constraints"],
      "failure_conditions": ["policy conflict", "insufficient authority", "unsafe task"],
      "output_schema": {
        "gate_decision": "enum(allow|narrow|refuse|hold)",
        "allowed_sources": ["string"],
        "allowed_actions": ["string"],
        "response_mode": "string",
        "must_cite": "boolean",
        "must_refuse_if_insufficient": "boolean"
      }
    },
    "M3": {
      "name": "Query Interpretation Module",
      "role": "Transforms user request into retrieval-ready form",
      "inputs": ["normalized query", "domain ontology", "prior session context"],
      "outputs": ["semantic retrieval query", "keyword retrieval query", "policy query", "expected answer type"]
    },
    "M4": {
      "name": "Retrieval Module",
      "role": "Finds candidate evidence from governed memory",
      "inputs": ["semantic query", "keyword query", "source constraints", "retrieval thresholds"],
      "outputs": ["retrieved evidence candidates", "similarity scores", "metadata"],
      "subcomponents": ["M4a Vector Retrieval", "M4b Lexical Retrieval", "M4c Policy Retrieval", "M4d Case Memory Retrieval"]
    },
    "M5": {
      "name": "Evidence Validation Module",
      "role": "Filters retrieved evidence before inference",
      "inputs": ["candidate evidence set", "trust rules", "recency rules", "relevance threshold"],
      "outputs": ["validated evidence set", "rejected evidence set", "evidence sufficiency score"],
      "critical_rule": "If evidence insufficient, emit INSUFFICIENT_GROUNDING and block open generation",
      "output_schema": {
        "validated_evidence": ["object"],
        "rejected_evidence": ["object"],
        "sufficiency_score": "float",
        "is_sufficient": "boolean",
        "failure_reason": "string|null"
      }
    },
    "M6": {
      "name": "Context Assembly Module",
      "role": "Constructs bounded context packet for inference",
      "inputs": ["validated evidence", "response constraints", "max context budget"],
      "outputs": ["context packet", "citation map", "answer instructions"]
    },
    "M7": {
      "name": "Inference Module",
      "role": "Performs bounded reasoning over validated context",
      "inputs": ["context packet", "user query", "inference policy"],
      "outputs": ["candidate answer", "claim list", "uncertainty markers"],
      "constraints": ["Answer ONLY from supplied evidence", "Mark unsupported claims", "Prefer refusal over gap-filling"]
    },
    "M8": {
      "name": "Output Verification Module",
      "role": "Checks if generated answer is supported",
      "inputs": ["candidate answer", "claims", "citation map", "validated evidence"],
      "outputs": ["verified answer", "unsupported claims", "verification score", "final recommendation"],
      "critical_rule": "Any claim with insufficient support triggers removal, regeneration, refusal, or hold",
      "output_schema": {
        "verification_score": "float",
        "unsupported_claims": ["object"],
        "contradictions_found": ["object"],
        "recommended_action": "enum(release|revise|refuse|hold)"
      }
    },
    "M9": {
      "name": "Decision Module",
      "role": "Produces final governed outcome",
      "inputs": ["governance state", "evidence sufficiency", "verification result", "risk tier"],
      "outputs": ["final answer", "refusal", "escalation", "hold state"],
      "allowed_outcomes": ["APPROVED", "PARTIAL", "PAUSE", "HOLD", "VOID"]
    },
    "M10": {
      "name": "Audit & Trace Module",
      "role": "Stores chain of evidence, decisions, and gates",
      "inputs": ["retrieval metadata", "validation outcomes", "final response", "policy decisions"],
      "outputs": ["audit record", "trace id", "reproducibility bundle"]
    }
  },
  "metadata_mapping": {
    "source_dataset": "ariffazil/APEX_THEORY",
    "mapping": {
      "id": "doc_id",
      "text": "content",
      "type": "tags",
      "amanah_score": "trust_tier",
      "governance_floor": "governance_floor"
    },
    "static_fields": {
      "source": "hf_apex_theory_v0"
    },
    "computed_fields": {
      "chunk_id": "sha256(text)",
      "version": "iso8601(now)"
    }
  },
  "failure_state_taxonomy": {
    "F001": "INPUT_AMBIGUOUS",
    "F002": "POLICY_BLOCKED",
    "F003": "SOURCE_UNTRUSTED",
    "F004": "GROUNDING_INSUFFICIENT",
    "F005": "CLAIM_UNSUPPORTED",
    "F006": "CONTRADICTION_FOUND",
    "F007": "HUMAN_REQUIRED",
    "F008": "TRACE_BROKEN",
    "F009": "CONTEXT_OVERFLOW",
    "F010": "INTEGRITY_VOID"
  }
}
