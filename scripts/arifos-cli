#!/usr/bin/env python3
"""
arifos-cli — Sovereign Client Interface

Lightweight CLI wrapper that handles:
- SALAM handshake (init_anchor_state)
- Governance token storage and injection
- Session continuity management
- MCP request wrapping

Usage:
    arifos-cli login --actor-id arif --authority-level sovereign
    arifos-cli call arifOS_kernel --query "What is the state of arifOS?"
    arifos-cli status
    arifos-cli logout

DITEMPA BUKAN DIBERI — Forged, Not Given
"""

import argparse
import json
import os
import sys
import time
from pathlib import Path
from typing import Any, Dict, Optional

import httpx

CONFIG_DIR = Path.home() / ".config" / "arifos"
TOKEN_FILE = CONFIG_DIR / "governance_token.json"
SESSION_FILE = CONFIG_DIR / "session.json"
MCP_URL = os.getenv("ARIFOS_MCP_URL", "http://localhost:8080/mcp")


def ensure_config_dir():
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)


def load_session() -> Optional[Dict[str, Any]]:
    if not SESSION_FILE.exists():
        return None
    try:
        with open(SESSION_FILE, "r") as f:
            return json.load(f)
    except Exception:
        return None


def save_session(session: Dict[str, Any]):
    ensure_config_dir()
    with open(SESSION_FILE, "w") as f:
        json.dump(session, f, indent=2)


def clear_session():
    if SESSION_FILE.exists():
        SESSION_FILE.unlink()
    if TOKEN_FILE.exists():
        TOKEN_FILE.unlink()


def cmd_login(args):
    print(f"🔐 Initiating SALAM handshake as {args.actor_id}...")
    
    payload = {
        "jsonrpc": "2.0",
        "id": int(time.time()),
        "method": "tools/call",
        "params": {
            "name": "init_anchor_state",
            "arguments": {
                "declared_name": args.actor_id,
                "authority_level": args.authority_level or "user",
            }
        }
    }
    
    try:
        with httpx.Client(timeout=30.0) as client:
            response = client.post(MCP_URL, json=payload, headers={"Content-Type": "application/json"})
            response.raise_for_status()
            result = response.json()
    except Exception as e:
        print(f"❌ Handshake failed: {e}")
        sys.exit(1)
    
    if "result" not in result:
        print(f"❌ Invalid response: {result}")
        sys.exit(1)
    
    content = result["result"].get("content", [{}])[0]
    if isinstance(content, dict):
        content = content.get("text", "{}")
    if isinstance(content, str):
        data = json.loads(content)
    else:
        data = content
    
    if not data.get("ok"):
        print(f"❌ Init failed: {data.get('error', 'Unknown error')}")
        if data.get("verdict") == "HOLD":
            print(f"   Machine Issue: {data.get('machine_issue', 'Unknown')}")
            print(f"   Next Action: Run init_anchor_state first")
        sys.exit(1)
    
    session = {
        "session_id": data.get("session_id"),
        "actor_id": data.get("authority", {}).get("actor_id", args.actor_id),
        "authority_level": data.get("authority", {}).get("level", args.authority_level or "user"),
        "auth_context": data.get("auth_context"),
        "governance_token": data.get("payload", {}).get("governance_token"),
        "created_at": time.time(),
        "mcp_url": MCP_URL,
    }
    
    save_session(session)
    
    print(f"✅ Session initialized")
    print(f"   Session ID: {session['session_id']}")
    print(f"   Actor: {session['actor_id']}")
    print(f"   Authority: {session['authority_level']}")
    print(f"   Token: {session['governance_token'][:16]}...")
    print(f"   Config: {SESSION_FILE}")


def cmd_logout(args):
    session = load_session()
    if not session:
        print("⚠️ No active session")
        return
    
    print(f"🔐 Revoking session {session['session_id'][:16]}...")
    
    payload = {
        "jsonrpc": "2.0",
        "id": int(time.time()),
        "method": "tools/call",
        "params": {
            "name": "revoke_anchor_state",
            "arguments": {
                "session_id": session["session_id"],
                "reason": args.reason or "User logout",
                "revoked_by": session.get("actor_id", "sovereign"),
            }
        }
    }
    
    try:
        with httpx.Client(timeout=10.0) as client:
            response = client.post(MCP_URL, json=payload, headers={"Content-Type": "application/json"})
            response.raise_for_status()
    except Exception as e:
        print(f"⚠️ Revocation request sent (non-blocking): {e}")
    
    clear_session()
    print("✅ Session revoked and cleared")


def cmd_status(args):
    session = load_session()
    if not session:
        print("⚠️ No active session. Run 'arifos-cli login' first.")
        return
    
    print(f"📋 Session Status")
    print(f"   Session ID: {session.get('session_id', 'Unknown')}")
    print(f"   Actor: {session.get('actor_id', 'Unknown')}")
    print(f"   Authority: {session.get('authority_level', 'Unknown')}")
    print(f"   MCP URL: {session.get('mcp_url', MCP_URL)}")
    
    age = time.time() - session.get("created_at", time.time())
    print(f"   Age: {int(age / 60)} minutes")
    
    if age > 900:
        print("⚠️ Session may have expired (TTL ~15 min)")


def cmd_call(args):
    session = load_session()
    if not session:
        print("❌ No active session. Run 'arifos-cli login' first.")
        sys.exit(1)
    
    tool_name = args.tool
    tool_args = {}
    
    if args.query:
        tool_args["query"] = args.query
    if args.input:
        tool_args["input"] = args.input
    if args.url:
        tool_args["url"] = args.url
    
    if args.args:
        for arg in args.args:
            if "=" in arg:
                key, value = arg.split("=", 1)
                try:
                    value = json.loads(value)
                except json.JSONDecodeError:
                    pass
                tool_args[key] = value
    
    if session.get("auth_context"):
        tool_args["auth_context"] = session["auth_context"]
    tool_args["session_id"] = session.get("session_id", "global")
    
    payload = {
        "jsonrpc": "2.0",
        "id": int(time.time()),
        "method": "tools/call",
        "params": {
            "name": tool_name,
            "arguments": tool_args
        }
    }
    
    print(f"🚀 Calling {tool_name}...")
    
    try:
        with httpx.Client(timeout=args.timeout or 60.0) as client:
            response = client.post(
                MCP_URL,
                json=payload,
                headers={"Content-Type": "application/json"}
            )
            response.raise_for_status()
            result = response.json()
    except Exception as e:
        print(f"❌ Call failed: {e}")
        sys.exit(1)
    
    if args.raw:
        print(json.dumps(result, indent=2))
        return
    
    if "result" in result:
        content = result["result"].get("content", [{}])
        if content and isinstance(content[0], dict):
            text = content[0].get("text", "{}")
            try:
                data = json.loads(text)
                print(json.dumps(data, indent=2))
            except json.JSONDecodeError:
                print(text)
        else:
            print(content)
    else:
        print(json.dumps(result, indent=2))


def main():
    parser = argparse.ArgumentParser(
        prog="arifos-cli",
        description="Sovereign Client Interface for arifOS MCP",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)
    
    login_parser = subparsers.add_parser("login", help="Initialize session via SALAM handshake")
    login_parser.add_argument("--actor-id", required=True, help="Your actor identity (e.g., 'arif')")
    login_parser.add_argument("--authority-level", default="user", help="Authority level (anonymous, user, admin, sovereign)")
    login_parser.set_defaults(func=cmd_login)
    
    logout_parser = subparsers.add_parser("logout", help="Revoke current session")
    logout_parser.add_argument("--reason", default="User logout", help="Reason for revocation")
    logout_parser.set_defaults(func=cmd_logout)
    
    status_parser = subparsers.add_parser("status", help="Show current session status")
    status_parser.set_defaults(func=cmd_status)
    
    call_parser = subparsers.add_parser("call", help="Call an MCP tool")
    call_parser.add_argument("tool", help="Tool name (e.g., arifOS_kernel, search_reality)")
    call_parser.add_argument("--query", "-q", help="Query string for the tool")
    call_parser.add_argument("--input", "-i", help="Input string")
    call_parser.add_argument("--url", "-u", help="URL for ingest_evidence")
    call_parser.add_argument("--timeout", "-t", type=int, default=60, help="Timeout in seconds")
    call_parser.add_argument("--raw", "-r", action="store_true", help="Raw JSON output")
    call_parser.add_argument("args", nargs="*", help="Additional arguments as key=value")
    call_parser.set_defaults(func=cmd_call)
    
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()