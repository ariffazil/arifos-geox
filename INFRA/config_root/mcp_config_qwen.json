{
  "mcpServers": {
    "arifos": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/ariffazil/arifosmcp.git",
        "arifos",
        "stdio"
      ],
      "env": {
        "ARIFOS_ENV": "production",
        "GOVERNANCE_MODE": "HARD"
      }
    }
  }
}
