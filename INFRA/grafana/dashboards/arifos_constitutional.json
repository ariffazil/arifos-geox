{
  "title": "arifOS Constitutional Intelligence",
  "uid": "arifos-constitutional-v1",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["arifos", "constitutional", "governance"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Tool Calls",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] }, "unit": "short" }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(arifos_requests_total)",
        "legendFormat": "Total Calls"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Sessions",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] }, "unit": "short" }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "arifos_sessions_active",
        "legendFormat": "Active"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Vault Entries Sealed",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": null }] }, "unit": "short" }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "arifos_vault_entries_total",
        "legendFormat": "Sealed"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Constitutional Violations",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }] }, "unit": "short" }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(arifos_floor_violations_total)",
        "legendFormat": "Violations"
      }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Tool Call Rate by Mega-Tool",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(arifos_requests_total[2m])",
        "legendFormat": "{{method}}"
      }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Metabolic Loop Latency (p50 / p95 / p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, rate(arifos_metabolic_loop_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(arifos_metabolic_loop_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, rate(arifos_metabolic_loop_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Genius Score (G) — Target ≥ 0.80",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2 }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.6 }, { "color": "green", "value": 0.8 }] } }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "arifos_genius_score",
        "legendFormat": "G — {{tool}}"
      }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Entropy Delta (ΔS) — Target ≤ 0",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0 }, { "color": "red", "value": 0.3 }] } }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "arifos_entropy_delta",
        "legendFormat": "ΔS — {{tool}}"
      }]
    },
    {
      "id": 9,
      "type": "piechart",
      "title": "Verdict Distribution",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] } },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum by (verdict) (arifos_verdicts_total)",
        "legendFormat": "{{verdict}}"
      }]
    },
    {
      "id": 10,
      "type": "logs",
      "title": "VOID Events (Constitutional Violations)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "increase(arifos_void_events_total[5m])",
        "legendFormat": "VOID — {{floor}}"
      }]
    }
  ]
}
